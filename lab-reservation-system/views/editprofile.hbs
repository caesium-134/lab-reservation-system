<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Edit Profile</title>
  <link rel="stylesheet" href="css/style.css">
</head>
<body class="edit-profile-page">
  <div class="edit-profile-container">
    <h1>Edit Profile</h1>
<form action="/editprofile" method="POST" enctype="multipart/form-data" class="edit-profile-form">
      <div class="profile-picture-section">
        <label for="profile-picture">Profile Picture</label>
        <input type="file" id="profile-picture" name="profile-picture" accept="image/*">
        <input type="hidden" id="profilePicBase64" name="profilePic">
        <div class="current-picture">
          <img src="{{user.profilePic}}" alt="Current Profile Picture" id="current-pic">
        </div>
      </div>

      <div class="basic-info-section">
        <h2>Basic Information</h2>
        <label for="id-number">ID Number</label>
        <input type="text" class = "edit-profile-txt" id="id-number" name="id-number" value="{{user.idNumber}}" readonly>
        <input type="email" class = "edit-profile-txt" id="email" name="email" value="{{user.email}}">

        <label for="name">Name</label>
        <input type="text" class = "edit-profile-txt" id="name" name="name" value="{{user.name}}">

        <label for="bio">Bio</label>
        <textarea id="bio" name="bio" rows="4">{{user.bio}}</textarea>
      </div>

      <div class="stats-section">
        <h2>Additional Details</h2>
        <label for="school-year">School Year</label>
        <select class = "edit-profile-select" id="school-year" name="school-year">
          <option value="1st Year" {{#eq ../user.schoolYear "1st Year"}}selected{{/eq}}>1st Year</option>
          <option value="2nd Year" {{#eq ../user.schoolYear "2nd Year"}}selected{{/eq}}>2nd Year</option>
          <option value="3rd Year" {{#eq ../user.schoolYear "3rd Year"}}selected{{/eq}}>3rd Year</option>
          <option value="4th Year" {{#eq ../user.schoolYear "4th Year"}}selected{{/eq}}>4th Year</option>
          <option value="5th Year" {{#eq ../user.schoolYear "5th Year"}}selected{{/eq}}>5th Year</option>
        </select>

        <label for="birthday">Birthday</label>
        <input type="date" class = "edit-profile-date" id="birthday" name="birthday" value="{{user.birthday}}">

        <label for="college">College</label>
        <select class= "edit-profile-select" id="college" name="college">
          <option value="">Select College</option>
          <option value="COLLEGE OF COMPUTER STUDIES" {{#eq user.college "COLLEGE OF COMPUTER STUDIES"}}selected{{/eq}}>COLLEGE OF COMPUTER STUDIES</option>
          <option value="BR. ANDREW GONZALEZ COLLEGE OF EDUCATION" {{#eq user.college "BR. ANDREW GONZALEZ COLLEGE OF EDUCATION"}}selected{{/eq}}>BR. ANDREW GONZALEZ COLLEGE OF EDUCATION</option>
          <option value="COLLEGE OF LIBERAL ARTS" {{#eq user.college "COLLEGE OF LIBERAL ARTS"}}selected{{/eq}}>COLLEGE OF LIBERAL ARTS</option>
          <option value="COLLEGE OF SCIENCE" {{#eq user.college "COLLEGE OF SCIENCE"}}selected{{/eq}}>COLLEGE OF SCIENCE</option>
          <option value="GOKONGWEI COLLEGE OF ENGINEERING" {{#eq user.college "GOKONGWEI COLLEGE OF ENGINEERING"}}selected{{/eq}}>GOKONGWEI COLLEGE OF ENGINEERING</option>
          <option value="RAMON V. DEL ROSARIO COLLEGE OF BUSINESS" {{#eq user.college "RAMON V. DEL ROSARIO COLLEGE OF BUSINESS"}}selected{{/eq}}>RAMON V. DEL ROSARIO COLLEGE OF BUSINESS</option>
          <option value="CARLOS L. TIU SCHOOL OF ECONOMICS" {{#eq user.college "CARLOS L. TIU SCHOOL OF ECONOMICS"}}selected{{/eq}}>CARLOS L. TIU SCHOOL OF ECONOMICS</option>
        </select>

        <label for="course">Course</label>
        <select class = "edit-profile-select"id="course" name="course">
          <option value="">Select Course</option>
        </select>
      </div>

      <div class="form-actions">
        <button type="submit" class="edit-profile-btn">Save Profile</button>
        <button type="button" onclick="window.location.href='/dashboard'">Cancel</button>
      </div>
    </form>
  </div>

  <script>
    const courses = {
      // ... same courses dict unchanged ...
    };

    const collegeSelect = document.getElementById('college');
    const courseSelect = document.getElementById('course');

    // Image preview and base64 to hidden field
    document.getElementById("profile-picture").addEventListener("change", function () {
      const file = this.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = function () {
        document.getElementById("current-pic").src = reader.result;
        document.getElementById("profilePicBase64").value = reader.result;
      };
      reader.readAsDataURL(file);
    });

    // College change populates courses
    collegeSelect.addEventListener('change', function() {
      const selectedCollege = this.value;
      courseSelect.innerHTML = '<option value="">Select Course</option>';
      if (selectedCollege && courses[selectedCollege]) {
        courses[selectedCollege].forEach(course => {
          const option = document.createElement('option');
          option.value = course;
          option.textContent = course;
          courseSelect.appendChild(option);
        });
      }
    });

    // On load, populate course options if college selected
    document.addEventListener("DOMContentLoaded", function () {
      collegeSelect.dispatchEvent(new Event('change'));
      courseSelect.value = "{{user.course}}"; // set if matches
    });
  </script>
</body>
</html>
