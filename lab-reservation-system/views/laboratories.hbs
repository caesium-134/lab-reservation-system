<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8"> 
        <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
        <title>Lab Reservation System</title>
        <link rel="stylesheet" href="css/style.css"> 
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
        <link rel="icon" type="image/x-icon" href="src/favicon.png">
    </head>
    <body> 
        <div class="header">
            <div class="header-left">
                Lab Reservation System
            </div>
            <div class="header-right">
                <div class="username">
                    {{user.name}}
                </div>
                <img src="{{user.profilePic}}">
                <div id="logout">
                    Logout
                    <span><i class="fa fa-sign-out" aria-hidden="true"></i></span>
                </div>
            </div>
        </div>

        <div class="content">
            <div class="sidebar">
                <div class="nav"><a href="dashboard">Dashboard</a></div>
                <div class="nav" id="dashboard-nav">Laboratories</div>
                <div class="nav"><a href="reservation">Reservations</a></div>
                <div class="nav"><a href="about">About</a></div>
            </div>
        
            <div class="main-content">
                <div class="lab-header">
                    <h1>Laboratories</h1> 
                </div>
                <div class="lab-container">
                    <div class="filter-section">
                        <label>Filter by Availability:</label>
                        <select id="avail-filter">
                            <option value="all">All</option>
                            <option value="available">Available</option>
                            <option value="unavailable">Unavailable</option>
                        </select>
                        <label>Filter by Room: </label>
                        <select id="room-filter">
                            <option value="all">All</option>
                            <option value="G">Gokongwei (G)</option>
                            <option value="V">Velasco (V)</option>
                        </select>
                    </div>
                    <br> 
                    <div class="card-container-wrapper">
                    {{#each labs}}
                    <div class="card-container" data-status="{{status}}" data-room="{{room}}"> 
                        <div class="card-header {{#eq status 'available'}}card-available{{/eq}}"> 
                            <h1><a href="/reservation">{{name}}</a></h1>
                            <h5>Room: {{room}}</h5>
                            <h5>Capacity: {{capacity}} seats</h5>
                            <h5>Status: {{status}}</h5>
                        </div>
                        <div class="card-description"> 
                            <h4>{{description}}</h4>
                        </div>
                        <div style="display: flex; margin: auto; padding-left: 7.5vw">
                            <img src="{{image}}" style="width: 5wv; height: 16vw">
                        </div>
                    </div>
                    <br><br>
                    {{/each}}
                    </div>

                </div>
                
            </div>
        </div>

        <script>
            document.getElementById("logout").addEventListener("click", function() {
                window.location.href = "/logout";
            });

            function applyFilters() {
                const availValue = document.getElementById("avail-filter").value;
                const roomValue = document.getElementById("room-filter").value;
                const cards = document.querySelectorAll(".card-container");

                cards.forEach(card => {
                    const status = card.getAttribute("data-status");
                    const room = card.getAttribute("data-room");

                    const availMatch = availValue === "all" || status === availValue;
                    const roomMatch = roomValue === "all" || room.startsWith(roomValue);

                    card.style.display = (availMatch && roomMatch) ? "" : "none";
                });
            }

            document.getElementById("avail-filter").addEventListener("change", applyFilters);
            document.getElementById("room-filter").addEventListener("change", applyFilters);
        </script>
    </body>
</html>
