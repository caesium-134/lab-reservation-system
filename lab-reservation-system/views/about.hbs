<!DOCTYPE html>
<html>
    <head>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
        <link href="css/style.css" rel="stylesheet" type="text/css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
        <title>About - Lab Reservation System</title>
        <link rel="icon" type="image/x-icon" href="src/favicon.png">
    </head>
    <body>
        <div class="header">
            <div class="header-left">
                Lab Reservation System
            </div>
            <div class="header-right">
                <div class="username">
                    {{user.name}}
                </div>
                <img src="{{user.profilePic}}">
                <div id="logout">
                    Logout
                    <span><i class="fa fa-sign-out" aria-hidden="true"></i></span>
                </div>
            </div>
        </div>

        <div class="content">
            <div class="sidebar">
                <div class="nav"><a href="dashboard">Dashboard</a></div>
                <div class="nav"><a href="laboratories">Laboratories</a></div>
                <div class="nav"><a href="reservation">Reservations</a></div>
                <div class="nav" id="dashboard-nav"><a href="about">About</a></div>
            </div>

            <div class="main-content">
                <div class="dashboard-header">
                    About
                </div>

                <div style="padding: 24px; max-width: 700px;">

                    <h3 style="margin-bottom: 6px;">Lab Reservation System</h3>
                    <p style="color: #666; margin-bottom: 28px;">
                        A web application for reserving computer laboratory seats at De La Salle University.
                        Students can view seat availability, make reservations, and manage them.
                    </p>

                    <h4 style="margin-bottom: 14px;">NPM Packages</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
                        <thead>
                            <tr style="background: #f5f5f5; text-align: left;">
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Package</th>
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Version</th>
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">express</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">^5.2.1</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Web server and routing framework</td>
                            </tr>
                            <tr style="background: #fafafa;">
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">mongoose</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">^9.3.0</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">MongoDB object modeling and database access</td>
                            </tr>
                            <tr>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">express-handlebars</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">^8.0.6</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Handlebars template engine for server-side rendering</td>
                            </tr>
                            <tr style="background: #fafafa;">
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">express-session</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">^1.19.0</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Session management and user authentication</td>
                            </tr>
                            <tr>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">ejs</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">^5.0.1</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Embedded JavaScript templating</td>
                            </tr>
                        </tbody>
                    </table>

                    <h4 style="margin-top: 32px; margin-bottom: 14px;">Third-Party Libraries</h4>
                    <table style="width: 100%; border-collapse: collapse; font-size: 14px;">
                        <thead>
                            <tr style="background: #f5f5f5; text-align: left;">
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Library</th>
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Version</th>
                                <th style="padding: 10px 14px; border: 1px solid #ddd;">Purpose</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Bootstrap</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">5.3.2</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">UI components and responsive layout</td>
                            </tr>
                            <tr style="background: #fafafa;">
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Font Awesome</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">4.7.0</td>
                                <td style="padding: 10px 14px; border: 1px solid #ddd;">Icons used throughout the application</td>
                            </tr>
                        </tbody>
                    </table>

                </div>
            </div>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
        <script>
            document.getElementById("logout").addEventListener("click", function() {
                window.location.href = "/logout";
            });
        </script>
    </body>
</html>
