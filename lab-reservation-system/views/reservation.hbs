<script>
    const currentUser = {
        id: "{{user._id}}",
        name: "{{user.name}}"
    };
    const availableLabs = [{{#each labs}}"{{this.name}}"{{#unless @last}},{{/unless}}{{/each}}];
</script>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Lab Reservation System</title>
    <link rel="stylesheet" href="css/style.css">
    <link rel="icon" type="image/x-icon" href="src/favicon.png">
</head>
<body>
    <div class="header">
        <div class="header-left">
            Lab Reservation System
        </div>
        <div class="header-right">
            <div class="username">
                {{user.name}}
            </div>

    <div class="container">
        
        <div class="reservation-section">
            
            <h2>Seat Reservations</h2>
            
            <div class="week-selector">
                <button onclick="changeWeek(-1)" class="btn-secondary">Previous Week</button>
                <span id="week-display"></span>
                <button onclick="changeWeek(1)" class="btn-secondary">Next Week</button>
            </div>

            <div class="filter-section">
                <label> Search Slot:</label>
                <select id="lab-filter">
                    <option value="lab">Laboratory</option>
                    <option value="lab1">Lab 1</option>
                    <option value="lab2">Lab 2</option>
                    <option value="lab3">Lab 3</option>
                </select>
                <select id="day-filter">
                    <option value="all-day">Day</option>
                    <option value="Mon">Monday</option>
                    <option value="Tues">Tuesday</option>
                    <option value="Wed">Wednesday</option>
                    <option value="Thurs">Thursday</option>
                    <option value="Fri">Friday</option>
                    <option value="Sat">Saturday</option>
                </select>
                <select id="time-filter">
                    <option value="all-time">Time</option>
                    <option value="time1">7:30 - 9:00 am</option>
                    <option value="time2">11:00 - 12:30 pm</option>
                </select>
            </div>
            <label>
                Reserve anonymously
                <input type="checkbox" id="anonymous-toggle">
            </label>
             
            <br> 
            
            <div class="laboratory-section">
                <h1>Computer Lab A</h1>
            </div>
            
            <div id="reservation-calendar"></div>              
        </div>
    </div>
    <div class="content">
        <div class="sidebar">
            <div class="nav"><a href="dashboard">Dashboard</a></div>
            <div class="nav"><a href="laboratories">Laboratories</a></div>
            <div class="nav" id="dashboard-nav">Reservations</div>
        </div>

        <div class="container">
            <div class="reservation-section">
                <h2>Seat Reservations</h2>
                <div class="week-selector">
                    <button class="btn-secondary">Previous Week</button>
                    <span id="week-display"></span>
                    <button class="btn-secondary">Next Week</button>
                </div>

                <div class="filter-section">
                    <label>Select Lab:</label>
                    <select id="lab-filter" onchange="loadReservationCalendar()">
                        {{#each labs}}
                        <option value="{{this.name}}">{{this.name}}</option>
                        {{/each}}
                    </select>
                </div>

                <div class="filter-section">
                    <label>Filter by Day:</label>
                    <select id="day-filter">
                        <option value="all">All</option>
                        <option value="Mon">Monday</option>
                        <option value="Tues">Tuesday</option>
                        <option value="Wed">Wednesday</option>
                        <option value="Thurs">Thursday</option>
                        <option value="Fri">Friday</option>
                        <option value="Sat">Saturday</option>
                    </select>
                </div>
                <div class="search-user">
                    <input type="textbox" placeholder="Search Slot">
                </div>
                <div id="reservation-calendar"></div>
            </div>
        </div>
    </div>
    <script src="/js/reservations.js"></script>
</body>
</html>
