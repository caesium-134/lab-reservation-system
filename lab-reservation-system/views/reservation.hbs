<!DOCTYPE html>
<html lang="en">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Lab Reservation System</title>
        <link rel="stylesheet" href="css/style.css">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">
        <link rel="icon" type="image/x-icon" href="src/favicon.png">
    </head>
    <body>
        <div class="header">
            <div class="header-left">
                Lab Reservation System
            </div>
            <div class="header-right">
                <div class="username">
                    {{user.name}}
                </div>
                <img src="{{user.profilePic}}">
                <div id="logout">
                    Logout
                    <span><i class="fa fa-sign-out" aria-hidden="true"></i></span>
                </div>
            </div>
        </div>

        <div class="content">
            <div class="sidebar">
                <div class="nav"><a href="dashboard">Dashboard</a></div>
                <div class="nav"><a href="laboratories">Laboratories</a></div>
                <div class="nav" id="dashboard-nav">Reservations</div>
            </div>

            <div class="container">
                <div class="reservation-section">
                    <h2>Seat Reservations</h2>

                    <div class="week-selector">
                        <button onclick="changeWeek(-1)" class="btn-secondary">Previous Week</button>
                        <span id="week-display"></span>
                        <button onclick="changeWeek(1)" class="btn-secondary">Next Week</button>
                    </div>

                    <div class="filter-section">
                        <label>Select Lab:</label>
                        <select id="lab-filter" onchange="loadReservationCalendar()">
                            {{#each labs}}
                            <option value="{{this.name}}">{{this.name}}</option>
                            {{/each}}
                        </select>
                    </div>

                    <div class="filter-section">
                        <label>Filter by Day:</label>
                        <select id="day-filter">
                            <option value="all">All</option>
                            <option value="Mon">Monday</option>
                            <option value="Tues">Tuesday</option>
                            <option value="Wed">Wednesday</option>
                            <option value="Thurs">Thursday</option>
                            <option value="Fri">Friday</option>
                            <option value="Sat">Saturday</option>
                        </select>
                    </div>

                    <label>
                        Reserve anonymously
                        <input type="checkbox" id="anonymous-toggle">
                    </label>

                    <div id="reservation-calendar"></div>
                </div>
            </div>
        </div>

        <script>
            const currentUser = {
                id: "{{user._id}}",
                name: "{{user.name}}"
            };
            const availableLabs = [{{#each labs}}"{{this.name}}"{{#unless @last}},{{/unless}}{{/each}}];

            document.getElementById("logout").addEventListener("click", function() {
                window.location.href = "/logout";
            });
        </script>
        <script src="/js/reservations.js"></script>
    </body>
</html>
