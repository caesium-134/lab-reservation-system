<!DOCTYPE html>
<html lang="en"> 
<head>
    <meta charset="UTF-8"> 
    <meta name="viewport" content="width=device-width, initial-scale=1.0"> 
    <title>Lab Reservation</title>
    <link rel="stylesheet" href="css/style.css"> 
</head>
<body> 
    <div class = "header">
            <div class = "header-left">
                Lab Reservation System
            </div>

            <div class = "header-right">
                <div class = "username">
                    {{username}}
                </div>
                <img src = "https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQUsIKSMW9Ul2g-X5JYNNGZlKYAapvSFKx_7g&s">
            </div>
    </div>
    <div class = "content">
        <div class = "sidebar">
            <div class = "nav"><a href="dashboard.html">Dashboard</a></div>
            <div class = "nav"><a href="laboratories.html">Laboratories</a></div>
            <div class = "nav" id="dashboard-nav">Reservations</div>
        </div>

        <div class="reservation-container">
            <div class="reservation-section">
                <h2>Seat Reservations</h2>
                <div class="week-selector">
                    <button class="btn-secondary" onclick="changeWeek(-1)">Previous Week</button>
                    <span id="week-display"></span>
                    <button class="btn-secondary" onclick="changeWeek(1)">Next Week</button>
                </div>

                <div class="filter-section">
                    <label>Filter by Day:</label>
                    <select id="day-filter" onchange="filterReservations()">
                        <option value="all">All</option>
                        <option value="Monday">Monday</option>
                        <option value="Tuesday">Tuesday</option>
                        <option value="Wednesday">Wednesday</option>
                        <option value="Thursday">Thursday</option>
                        <option value="Friday">Friday</option>
                        <option value="Saturday">Saturday</option>
                    </select>
                </div>
                <div class = "search-user">
                    <input type="text" id="slot-search" placeholder="Search Slot" oninput="searchSlots()">
                </div>

                <div id="reservation-calendar"></div>
                
                <div id="booking-modal" class="modal" style="display:none;">
                    <div class="modal-content">
                        <h3>Make Reservation</h3>
                        <div id="booking-details"></div>
                        <button onclick="confirmBooking()" class="btn-primary">Confirm Booking</button>
                        <button onclick="closeModal()" class="btn-secondary">Cancel</button>
                    </div>
                </div>

            </div>
        </div>
    </div>      
         
    <script src="/reservations.js"></script>
    
</body>
</html>



